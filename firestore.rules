rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return signedIn() && exists(/databases/$(database)/documents/admin/$(request.auth.uid));
    }

    match /items/{itemId} {
      allow read: if true;
      allow write: if false;
    }

    match /costumes/{costumeId} {
      allow read: if true;
      allow write: if false;
    }

    // 어드민 목록: Firebase 콘솔에서만 쓸 수 있고, 본인 문서만 읽기 허용.
    match /admin/{userId} {
      allow read: if isOwner(userId);
      allow write: if false;
    }

    // 무기 정본 모션(Tier-1): 전체 read, 어드민만 write.
    match /weapon_motions/{weaponKey} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // 공방 무기(Tier-2): published 또는 작성자/어드민만 read; 작성자만 생성/수정,
    // 어드민은 모더레이션(status) 가능. 누구나 카운터(likes/plays/reports)만 증가 가능.
    match /workshop_weapons/{weaponId} {
      allow read: if resource.data.status == 'published'
                  || isOwner(resource.data.author_id) || isAdmin();
      allow create: if isOwner(request.resource.data.author_id);
      allow update: if isOwner(resource.data.author_id) || isAdmin()
                  || (signedIn() && request.resource.data.diff(resource.data)
                        .affectedKeys().hasOnly(['likes', 'plays', 'reports', 'updated_at']));
      allow delete: if isOwner(resource.data.author_id) || isAdmin();
    }

    match /profiles/{userId} {
      allow read: if true;
      allow create, update: if isOwner(userId);
      allow delete: if false;

      match /user_items/{itemId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId);
        allow update, delete: if false;
      }

      match /user_costumes/{costumeId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId);
        allow update, delete: if false;
      }

      match /match_logs/{logId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId);
        allow update, delete: if false;
      }
    }
  }
}
